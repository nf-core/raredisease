process {

    withName: 'BCFTOOLS_REHEADER' {
        beforeScript = { "echo ${meta.samplename} > ${meta.samplename}.txt" }
        ext.args   = { "--samples ${meta.samplename}.txt" }
        ext.args2  = "--output-type z --write-index=tbi"
        ext.prefix = { "${meta.samplename}_truthvcf" }
    }

}
