process {
    withName: 'CALL_STRUCTURAL_VARIANTS:SVDB_MERGE' {
        ext.prefix = { "${meta.id}_sv" }
        ext.args   = '--pass_only --same_order'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_MANTA:MANTA' {
        ext.args = ''
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_MANTA:BCFTOOLS_VIEW_MANTA' {
        ext.prefix = { "${meta.id}_manta" }
        ext.args   = '--apply-filters .,PASS --output-type z'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_TIDDIT:TIDDIT_SV' {
        ext.args = '-p 2'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_TIDDIT:BCFTOOLS_VIEW_TIDDIT' {
        ext.prefix = { "${meta.id}_tiddit_bcftools" }
        ext.args   = '--apply-filters .,PASS --output-type z'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_TIDDIT:SVDB_MERGE_TIDDIT' {
        ext.args   = '--notag --pass_only'
        ext.prefix = { "${meta.id}_tiddit" }
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_CNVNATOR:CNVNATOR_HIST' {
        ext.args = '-genome GRCh38 -his 1000'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_CNVNATOR:CNVNATOR_STAT' {
        ext.args = '-genome GRCh38 -stat 1000'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_CNVNATOR:CNVNATOR_PARTITION' {
        ext.args = '-genome GRCh38 -partition 1000'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_CNVNATOR:CNVNATOR_CALL' {
        ext.args = '-genome GRCh38 -call 1000'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_CNVNATOR:CNVNATOR_CONVERT2VCF' {
        ext.prefix = { "${meta.id}_cnvnator" }
        ext.args   = '-reference GRCh38'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_CNVNATOR:BCFTOOLS_VIEW_CNVNATOR' {
        ext.prefix = { "${meta.id}_cnvnator_filter" }
        ext.args   = '--apply-filters .,PASS --output-type z'
    }

    withName: '.*CALL_STRUCTURAL_VARIANTS:CALL_SV_CNVNATOR:SVDB_MERGE_CNVNATOR' {
        ext.args   = '--notag --pass_only'
        ext.prefix = { "${meta.id}_cnvnator" }
    }

    withName: '.*CALL_SV_MT:MT_DELETION' {
        ext.args   = '-s --insert-size 16000'
        ext.prefix = { "${meta.id}_mitochondria_deletions" }
    }
}
