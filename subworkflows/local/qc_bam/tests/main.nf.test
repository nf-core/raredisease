                        workflow.out.mosdepth_summary_txt
                            .collect { _meta, files -> file(files).name },
                        workflow.out.mosdepth_per_base_bed
                            .collect { _meta, files -> file(files).name },
                        workflow.out.mosdepth_per_base_csi
