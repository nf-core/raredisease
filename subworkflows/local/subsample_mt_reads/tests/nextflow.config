process {

    withName: '.*SUBSAMPLE_MT_READS:SAMTOOLS_VIEW' {
        ext.args   = { "--output-fmt bam -F 0x400" }
        ext.prefix = { "${meta.id}_mt_nodups" }
    }

    withName: '.*SUBSAMPLE_MT_READS:SAMTOOLS_COLLATE' {
        ext.args   = { "--output-fmt sam" }
        ext.prefix = { "${meta.id}_mt_nodups_collate" }
    }

    withName: '.*SUBSAMPLE_MT_READS:GAWK' {
        ext.args2  = { "'/^@/ { print; next } count < ${params.mt_subsample_reads} || last == \$1 { print; last = \$1; count++ }'" }
        ext.prefix = { "${meta.id}_mt_nodups_collate_awk" }
        ext.suffix = "sam"
    }

    withName: '.*SUBSAMPLE_MT_READS:SAM_TO_BAM' {
        ext.args   = { "--output-fmt bam" }
        ext.prefix = { "${meta.id}_mt_nodups_collate_awk" }
    }

    withName: '.*SUBSAMPLE_MT_READS:SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}_mt_subsample" }
    }
}
